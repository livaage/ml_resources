#!/bin/bash
# Pre-commit hook: rebuild topic pages from sources, stage the outputs.
#
# Enabled via `make setup` (which runs `git config core.hooksPath hooks`).

set -e

# Prefer `uv run` because .md sources need the python-markdown library, which
# build.py declares as an inline script dependency. Fall back to plain
# python3 if uv isn't available (build.py will then assume markdown is
# already installed system-wide).
if command -v uv >/dev/null 2>&1; then
    RUNNER="uv run --quiet"
elif command -v python3 >/dev/null 2>&1; then
    RUNNER="python3"
else
    echo "[pre-commit] neither uv nor python3 found, skipping topic-page build" >&2
    exit 0
fi

# Build all topics. Fails loudly if any source is malformed.
$RUNNER build.py >&2

# Re-stage outputs that have a corresponding source file. Source extension
# can be .html (legacy) or .md (new format); both produce a sibling .html
# under the published topics/ tree.
find topics/_src \( -name '*.html' -o -name '*.md' \) -print0 |
while IFS= read -r -d '' src; do
    rel="${src#topics/_src/}"
    base="${rel%.*}"
    out="topics/$base.html"
    if [ -f "$out" ]; then
        git add "$out"
    fi
done

exit 0
